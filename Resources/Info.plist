<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>DirXplore</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>DirXplore</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>

	<!-- App Transport Security: Allow arbitrary loads for HTTP/FTP directories -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
		<key>NSAllowsArbitraryLoadsForMedia</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<!-- Face ID Usage Description -->
	<key>NSFaceIDUsageDescription</key>
	<string>DirXplore uses Face ID / Touch ID to lock the app and protect your privacy.</string>

	<!-- Photo Library Usage Descriptions -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DirXplore needs photo library access to save media files you download.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>DirXplore saves downloaded images and videos to your photo library when you choose.</string>

	<!-- Documents / Downloads Folder Usage -->
	<key>NSDocumentsFolderUsageDescription</key>
	<string>DirXplore needs access to documents to manage files you download and organize them.</string>
	<key>NSDesktopFolderUsageDescription</key>
	<string>DirXplore can save downloaded files to your Desktop folder if you choose.</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>DirXplore saves downloaded files to your Downloads folder for easy access.</string>

	<!-- Local Network Usage -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>DirXplore needs local network access to browse HTTP and FTP directories on your local network.</string>

	<!-- Bonjour Services -->
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
		<string>_ftp._tcp</string>
	</array>

	<!-- File Sharing -->
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- Background Modes -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>location</string>
		<string>processing</string>
		<string>download</string>
	</array>

	<!-- Location Usage Descriptions -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DirXplore can use your location to keep downloads active in the background.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>DirXplore uses location in the background to maintain download sessions.</string>

	<!-- Live Activities -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>NSSupportsLiveActivitiesFrequentUpdates</key>
	<true/>

	<!-- Scene Manifest - SwiftUI manages scenes -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>

	<!-- Interface Orientations -->
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Required Device Capabilities -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>

	<!-- Launch Screen -->
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
</dict>
</plist>
